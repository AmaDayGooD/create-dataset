# === ОБЯЗАТЕЛЬНЫЕ ===
PAGE_URL=твоя ссылка на видео, пример: https://rtsp.ru/embed/REdk5y1W/
VIDEO_SELECTOR=#video

# === НАСТРОЙКИ ===
SCREENSHOT_DIR=./screenshots
JPEG_QUALITY=85
VIEWPORT_WIDTH=1280
VIEWPORT_HEIGHT=720

# === ДИНАМИЧЕСКИЕ ИНТЕРВАЛЫ (для теста — короткие) ===
DAY_INTERVAL_SECONDS=30
NIGHT_INTERVAL_SECONDS=60
NIGHT_START_HOUR=21
NIGHT_END_HOUR=5

# === Для продакшена раскомментируйте и настройте: ===
DAY_INTERVAL_SECONDS=900
NIGHT_INTERVAL_SECONDS=1800

# === ЯНДЕКС.ДИСК ===
YANDEX_DISK_TOKEN=твой токен яндекса
YANDEX_DISK_FOLDER=disk:/create-dataset/